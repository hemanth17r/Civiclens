rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isAdmin() {
      return request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.email == 'hemanthreddya276@gmail.com'
      );
    }

    // Users Collection
    match /users/{userId} {
      // Anyone authenticated can read a user profile (needed for displaying names on reports)
      allow read: if isAuthenticated();
      // Only the user themselves can write to their own profile, but they CANNOT update sensitive fields.
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && isOwner(userId) && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny([
          // Gamification fields (server-only via Admin SDK)
          'xp', 'level', 'levelTitle', 'badges', 'gamificationStats',
          'currentStreak', 'longestStreak', 'lastActiveDate',
          // Trust fields (server-only)
          'trustScore', 'trustUpdatedAt', 'trustStats',
          // Moderation fields (admin-only)
          'isBlocked',
          // Role fields (admin-only)
          'role', 'department', 'jurisdiction',
          // Counter fields (transaction-managed, not directly settable)
          'followersCount', 'followingCount'
        ])
      );
      allow delete: if false; // Soft deletes preferred

      // Vote rate-limiting log (anti-manipulation)
      match /voteLog/{logId} {
        allow read, write: if isAuthenticated() && isOwner(userId);
      }
    }

    // Issues Collection
    match /issues/{issueId} {
      allow read: if true; // Public read for landing feed
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      
      // Non-owners can only update social counters/status flags. Owners can update general fields (but not change ownership)
      allow update: if isAuthenticated() && request.resource.data.userId == resource.data.userId && (
        isOwner(resource.data.userId) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votes', 'savesCount', 'commentCount', 'sharesCount', 'statusData', 'status', 'flagCount', 'isHidden'])
      );
      allow delete: if isAuthenticated() && isOwner(resource.data.userId);

      // Community flagging (anti-manipulation)
      match /flags/{flagId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow update, delete: if false;
      }

      // Hypes subcollection (stored as issues/{issueId}/hypes/{userId})
      match /hypes/{hypeId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isOwner(hypeId);
        allow delete: if isAuthenticated() && isOwner(hypeId);
        allow update: if false;
      }

      // Saves subcollection (stored as issues/{issueId}/saves/{userId})
      match /saves/{saveId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && isOwner(saveId);
        allow delete: if isAuthenticated() && isOwner(saveId);
        allow update: if false;
      }

      // Comments subcollection (stored as issues/{issueId}/comments/{commentId})
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update: if isAuthenticated() && isOwner(resource.data.userId);
        allow delete: if isAuthenticated() && isOwner(resource.data.userId);

        // Replies subcollection
        match /replies/{replyId} {
          allow read: if isAuthenticated();
          allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
          allow update: if isAuthenticated() && isOwner(resource.data.userId);
          allow delete: if isAuthenticated() && isOwner(resource.data.userId);
        }

        // Comment likes subcollection
        match /likes/{likeUserId} {
          allow read: if isAuthenticated();
          allow create: if isAuthenticated() && isOwner(likeUserId);
          allow delete: if isAuthenticated() && isOwner(likeUserId);
          allow update: if false;
        }
      }

      // Status votes subcollection (crowdsourced status voting)
      match /statusVotes/{voteId} {
        allow read: if isAuthenticated();
        // Users can only create/update their own votes (voteId starts with their UID)
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        allow update: if isAuthenticated() && resource.data.userId == request.auth.uid;
        allow delete: if false;
      }
    }

    // Follows Collection (top-level: follows/{followerId_targetId})
    match /follows/{followId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.followerId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }
    
    // Notifications — only admin or server-side (Admin SDK) can create
    // Users can only read/update/delete their own notifications
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.targetUid == request.auth.uid;
      allow create: if isAdmin(); // Only admin/server can create notifications (Admin SDK bypasses rules)
      allow update: if isAuthenticated() && resource.data.targetUid == request.auth.uid; // Marking as read
      allow delete: if isAuthenticated() && resource.data.targetUid == request.auth.uid;
    }
    
    // Feedbacks
    match /feedbacks/{feedbackId} {
      allow create: if isAuthenticated();
      // Only admins should read
      allow read: if isAdmin();
    }
    
    // User Reports
    match /user_reports/{reportId} {
      allow create: if isAuthenticated() && request.resource.data.reporterUid == request.auth.uid;
      allow read: if isAuthenticated() && (isOwner(resource.data.reporterUid) || isAdmin());
    }

    // Missions — only admin/server can create/update missions
    match /missions/{missionId} {
      allow read: if isAuthenticated();
      allow create, update: if isAdmin(); // Only admin can create/modify missions
      allow delete: if false;

      // Mission Progress (per-user)
      match /progress/{userId} {
        allow read: if isAuthenticated() && isOwner(userId);
        allow create, update: if false; // Only server (Admin SDK) can update mission progress
        allow delete: if false;
      }
    }
  }
}