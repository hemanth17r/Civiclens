# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — NEVER commit these
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# build logs & tsc output (dev artifacts)
build.txt
build_log.txt
tsc-out.txt
tsc_output.txt
tsc-errors.txt

# local test/dev scripts
test_endpoint.js

# Firebase debug logs (never commit)
firebase-debug.log
firebase-debug.*.log

# Locally cached user-uploaded media (served from Supabase in production)
/public/uploads/

# Antigravity / AI agent workspace
.gemini/
