rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Issue photos: authenticated users can upload images up to 10MB
    match /issue_photos/{fileName} {
      allow read: if true;
      allow create: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow update, delete: if false;
    }
    // Resolution photos: authenticated users can upload images up to 10MB
    match /resolution_photos/{fileName} {
      allow read: if true;
      allow create: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow update, delete: if false;
    }
    // Deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
